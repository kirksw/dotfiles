#!/usr/bin/env python3

from pathlib import Path
import pandas as pd

def list_files(inp_dir, ext='*'):
    p = Path(inp_dir)
    file_list = p.glob(f'{ext}')

    return list(file_list)

def make_df(files):
    if len(files) == 0:
        print('No files to process!')
        return

    frames = []

    for _ in files:
        frames.append(pd.read_parquet(_, compression='gzip'))

    df = pd.DataFrame()
    df.concat(frames, sort=True, copy=False)

    return df

if __name__ == "__main__":
    cur_dir = '/home/kirk/Projects/GEA/datasets/'
    ext_pattern = 'milcobel*'

    print(f'Listing files in [{cur_dir}] matching pattern [{ext_pattern}]')
    file_list = list_files(cur_dir, ext_pattern)
    print(f'Number of files found [{len(file_list)}]')

    for _ in file_list:
        print(f'- {_}')

    df = make_df(file_list)

    print(df.head())
